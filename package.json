{
  "name": "vaani",
  "productName": "Vaani",
  "version": "1.0.0",
  "description": "Premium macOS voice dictation powered by Groq Whisper.",
  "main": ".vite/build/main.js",
  "gypfile": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Onkarj012/Vaani.git"
  },
  "homepage": "https://github.com/Onkarj012/Vaani",
  "bugs": {
    "url": "https://github.com/Onkarj012/Vaani/issues"
  },
  "scripts": {
    "build:native": "npx node-gyp rebuild",
    "dev": "npm run build:native && node scripts/dev.js",
    "build": "npm run build:native && electron-forge package",
    "make": "npm run build:native && electron-forge make",
    "generate:update-metadata": "node scripts/generate-latest-mac-yml.js",
    "publish": "npm run build:native && electron-forge publish",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "electron",
    "dictation",
    "whisper",
    "groq",
    "macos",
    "voice",
    "transcription",
    "accessibility"
  ],
  "author": {
    "name": "Onkarj012",
    "url": "https://github.com/Onkarj012"
  },
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^0.19.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@electron-forge/publisher-github": "^7.8.1",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "clsx": "^2.1.1",
    "electron": "^35.1.5",
    "node-addon-api": "^8.3.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.1",
    "vitest": "^3.1.1"
  }
}
